# ── 복사해서 .env 로 사용 (.env 는 git 제외) ─────────────────────────

# ===== 저장소 =====
# 저장소 루트. 하위에 common/(공통)과 users/<id>/(개인) 폴더가 생성된다.
#  - 라즈베리파이: /mnt/hdd
#  - 로컬 개발(Windows): ./data
STORAGE_ROOT=/mnt/hdd

# ===== 인증 (필수, 수동 설정) =====
# 사용자 계정은 반드시 여기에 직접 적는다. JSON 배열 형식.
#   [{"username":"아이디","password":"비밀번호","display_name":"표시이름"}]
# display_name은 생략 가능. 비밀번호는 평문(내부 홈서버 전제) — 외부 노출 금지.
AUTH_USERS=[{"username":"admin","password":"change-me","display_name":"관리자"}]

# 세션 토큰 서명용 비밀키 (길고 무작위로). 미설정 시 서버가 거부.
SESSION_SECRET=please-generate-a-long-random-secret

# 세션 유효시간(초). 기본 3600(1시간). 만료 시 자동 로그아웃.
SESSION_TTL_SECONDS=3600

# HTTPS(Cloudflare Tunnel 등)로 접속하면 true 권장 — 쿠키를 암호화 연결로만 전송.
# 로컬 http 개발은 false.
COOKIE_SECURE=false

# ===== CORS =====
# 자격증명 쿠키를 쓰므로 '*' 금지. 실제 접속 오리진을 콤마로 명시.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ===== AI (Gemini) =====
GEMINI_API_KEY=
# 사용할 모델 (기본 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# ReAct 에이전트 1턴 최대 스킬 실행 횟수
AI_MAX_STEPS=8

# ===== Google Calendar 연동 (선택, 유저별) =====
# 환경변수 앞에 "<아이디>_" 접두사를 붙이면 그 유저의 캘린더에만 연결된다.
# 설정 없는 유저는 내부 캘린더 사용(유저 간 캘린더 격리).
# 예: admin 유저
# admin_GOOGLE_SERVICE_ACCOUNT_JSON=       # 방법 A) 서비스 계정 JSON 경로
# admin_GOOGLE_CLIENT_ID=                   # 방법 B) OAuth (아래 3개 세트)
# admin_GOOGLE_CLIENT_SECRET=
# admin_GOOGLE_REFRESH_TOKEN=
# admin_GOOGLE_CALENDAR_ID=primary
# 두 번째 유저가 있다면 bob_GOOGLE_CLIENT_ID=... 처럼 각자 추가.

# ===== 운영/보안 =====
# DEBUG=true 일 때만 에러 응답에 상세(예외/경로)를 노출. 운영은 false.
DEBUG=false
# 업로드 1건 최대 크기 (바이트). 기본 2GB.
MAX_UPLOAD_BYTES=2147483648
# Cloudflare Tunnel 토큰 (외부 접속). docker compose --profile tunnel up -d
CF_TUNNEL_TOKEN=

# ===== 웹 터미널 (admin 전용, 옵트인) =====
# ⚠️ 켜면 admin이 라즈베리파이 '호스트' 루트 셸에 접속할 수 있다(nsenter).
#    반드시 admin 비밀번호를 강하게 설정한 뒤에만 활성화할 것.
# 활성화: ENABLE_TERMINAL=true 로 두고
#    docker compose --profile terminal up -d --build
ENABLE_TERMINAL=false
# 터미널 사용 가능 계정(콤마구분). 기본 admin.
TERMINAL_ADMINS=admin
# CSWSH 방지용 허용 Origin(콤마구분). 비우면 요청 Host와 동일 출처만 허용.
# 외부 도메인으로 쓸 경우 명시 권장. 예)
# TERMINAL_ORIGINS=https://server.zanviq.dev,http://192.168.0.43
